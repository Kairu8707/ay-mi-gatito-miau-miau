-------------------------------------------------
-- MAIN RUNSERVICE HANDLER
-------------------------------------------------
RunService.RenderStepped:Connect(function()
	-- Spectate Attachments
	if spectateTarget and spectateTarget.Character then
		local root = char:FindFirstChild("HumanoidRootPart")
		local targetRoot = spectateTarget.Character:FindFirstChild("HumanoidRootPart")
		if root and targetRoot then
			if attachBack then root.CFrame = targetRoot.CFrame * CFrame.new(0, 0, 3)
			elseif attachFront then root.CFrame = targetRoot.CFrame * CFrame.new(0, 0, -3)
			elseif attachLeft then root.CFrame = targetRoot.CFrame * CFrame.new(-4, 0, 0)
			elseif attachRight then root.CFrame = targetRoot.CFrame * CFrame.new(4, 0, 0) end
		end
	end
	
	if healthEspEnabled then updateHealthESP() end

	-- TRACERS LOGIC
	for _, plr in pairs(Players:GetPlayers()) do
		if plr ~= player then
			if tracersEnabled and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
				if not tracers[plr.Name] then
					tracers[plr.Name] = Drawing.new("Line")
					tracers[plr.Name].Thickness = 1
					tracers[plr.Name].Color = Color3.new(1, 1, 1)
					tracers[plr.Name].Transparency = 0.6
				end
				local line = tracers[plr.Name]
				local vector, onScreen = workspace.CurrentCamera:WorldToViewportPoint(plr.Character.HumanoidRootPart.Position)
				if onScreen then
					line.From = Vector2.new(workspace.CurrentCamera.ViewportSize.X / 2, workspace.CurrentCamera.ViewportSize.Y)
					line.To = Vector2.new(vector.X, vector.Y)
					line.Visible = true
				else
					line.Visible = false
				end
			else
				if tracers[plr.Name] then tracers[plr.Name].Visible = false end
			end
		end
	end
	
	for name, line in pairs(tracers) do
		if not Players:FindFirstChild(name) then
			line:Remove()
			tracers[name] = nil
		end
	end

    -- Danger Sense Logic
    if dangerSenseEnabled and char and char:FindFirstChild("HumanoidRootPart") then
        local closestDist = dangerDistance
        local closestPlayer = nil
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (char.HumanoidRootPart.Position - plr.Character.HumanoidRootPart.Position).Magnitude
                if dist < closestDist then closestDist = dist closestPlayer = plr end
            end
        end
        if closestPlayer then
            dangerLabel.Text = "⚠️ DANGER: " .. closestPlayer.Name .. " [" .. math.floor(closestDist) .. " STUDS]"
            dangerLabel.Visible = true
            if dangerSoundEnabled and not hasPlayedAlert then alertSound:Play() hasPlayedAlert = true end
        else dangerLabel.Visible = false hasPlayedAlert = false end
    end
end)

