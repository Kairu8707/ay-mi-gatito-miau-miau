local function createSection(name, order)
	local sectionTitle = Instance.new("TextLabel", container)
	sectionTitle.Size = UDim2.new(1, 0, 0, 25)
	sectionTitle.Text = name:upper()
	sectionTitle.TextColor3 = Color3.fromRGB(120, 120, 120)
	sectionTitle.Font = Enum.Font.GothamBold
	sectionTitle.TextSize = 10
	sectionTitle.BackgroundTransparency = 1
	sectionTitle.LayoutOrder = order
end

local function makeButton(text, callback, order)
	local b = Instance.new("TextButton", container)
	b.Size = UDim2.new(1, -8, 0, 30)
	b.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
	b.Text = text
	b.TextColor3 = Color3.new(0.9, 0.9, 0.9)
	b.Font = Enum.Font.Gotham
	b.TextSize = 12
	b.BorderSizePixel = 0
	b.LayoutOrder = order
	Instance.new("UICorner", b).CornerRadius = UDim.new(0, 4)
	b.MouseButton1Click:Connect(callback)
	return b
end

local function makeStatLabel(text, order)
	local l = Instance.new("TextLabel", container)
	l.Size = UDim2.new(1, -10, 0, 18)
	l.BackgroundTransparency = 1
	l.TextColor3 = Color3.fromRGB(0, 200, 255)
	l.Font = Enum.Font.Code
	l.TextSize = 11
	l.TextXAlignment = Enum.TextXAlignment.Left
	l.Text = "  " .. text
	l.LayoutOrder = order
	return l
end

