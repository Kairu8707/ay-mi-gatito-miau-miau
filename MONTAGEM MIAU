UIS.InputBegan:Connect(function(input, gp)
	if gp then return end
	if input.KeyCode == Enum.KeyCode.RightShift then gui.Enabled = not gui.Enabled end
	if input.KeyCode == Enum.KeyCode.Y then toggleFly() end
	if input.KeyCode == Enum.KeyCode.N then noclip = not noclip end
	if input.KeyCode == Enum.KeyCode.T then teleportToMouse() end
	if input.KeyCode == Enum.KeyCode.G then infJump = not infJump end
	if input.KeyCode == Enum.KeyCode.E then espEnabled = not espEnabled updateESP() end
	if input.KeyCode == Enum.KeyCode.H then fullHealth() end
	if input.KeyCode == Enum.KeyCode.V then char.Humanoid.WalkSpeed += 10 end
	if input.KeyCode == Enum.KeyCode.B then char.Humanoid.WalkSpeed = 16 end
	if input.KeyCode == Enum.KeyCode.K then char.Humanoid.UseJumpPower = true char.Humanoid.JumpPower += 10 end
	if input.KeyCode == Enum.KeyCode.L then char.Humanoid.JumpPower = 50 end
	if input.KeyCode == Enum.KeyCode.P then 
		if spectateTarget then resetAttachments("back") attachBack = not attachBack end 
	end
	if input.KeyCode == Enum.KeyCode.U then flySpeed += 10 end
	if input.KeyCode == Enum.KeyCode.J then flySpeed = math.max(10, flySpeed - 10) end
end)
