			b.Font = Enum.Font.Gotham
			b.TextSize = 11
			Instance.new("UICorner", b).CornerRadius = UDim.new(0,3)
			b.MouseButton1Click:Connect(function()
				spectateTarget = plr
				if plr.Character then workspace.CurrentCamera.CameraSubject = plr.Character.Humanoid end
			end)
		end
	end
end

