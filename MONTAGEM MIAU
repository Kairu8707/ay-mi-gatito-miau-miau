UIS.InputBegan:Connect(function(input, gp)
	if gp then return end
	
	-- Menu Toggle
	if input.KeyCode == Enum.KeyCode.RightShift then gui.Enabled = not gui.Enabled end
	
	-- Movement Keys
	if input.KeyCode == Enum.KeyCode.Y then toggleFly() end
	if input.KeyCode == Enum.KeyCode.N then noclip = not noclip end
	if input.KeyCode == Enum.KeyCode.G then infJump = not infJump end
	if input.KeyCode == Enum.KeyCode.V then if char and char:FindFirstChild("Humanoid") then char.Humanoid.WalkSpeed += 10 end end
	if input.KeyCode == Enum.KeyCode.B then if char and char:FindFirstChild("Humanoid") then char.Humanoid.WalkSpeed = 16 end end
	if input.KeyCode == Enum.KeyCode.K then if char and char:FindFirstChild("Humanoid") then char.Humanoid.UseJumpPower = true char.Humanoid.JumpPower += 10 end end
	if input.KeyCode == Enum.KeyCode.L then if char and char:FindFirstChild("Humanoid") then char.Humanoid.JumpPower = 50 end end
	
	-- Utility Keys
	if input.KeyCode == Enum.KeyCode.T then teleportToMouse() end
	if input.KeyCode == Enum.KeyCode.H then fullHealth() end
	if input.KeyCode == Enum.KeyCode.U then flySpeed += 10 end
	if input.KeyCode == Enum.KeyCode.J then flySpeed = math.max(10, flySpeed - 10) end
	
	-- Visual Keys
	if input.KeyCode == Enum.KeyCode.E then espEnabled = not espEnabled updateESP() end
	
	-- Spectate Attach
	if input.KeyCode == Enum.KeyCode.P then 
		if spectateTarget then resetAttachments("back") end 
	end
end)
