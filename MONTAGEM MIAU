local function startFly()
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end
	bv = Instance.new("BodyVelocity", root)
	bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
	bg = Instance.new("BodyGyro", root)
	bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
	bg.P = 10000
	flyConnection = RunService.RenderStepped:Connect(function()
		if not flying then return end
		local cam = workspace.CurrentCamera
		local dir = Vector3.zero
		if UIS:IsKeyDown(Enum.KeyCode.W) then dir += cam.CFrame.LookVector end
		if UIS:IsKeyDown(Enum.KeyCode.S) then dir -= cam.CFrame.LookVector end
		if UIS:IsKeyDown(Enum.KeyCode.A) then dir -= cam.CFrame.RightVector end
		if UIS:IsKeyDown(Enum.KeyCode.D) then dir += cam.CFrame.RightVector end
		if dir.Magnitude > 0 then dir = dir.Unit end
		bv.Velocity = dir * flySpeed
		bg.CFrame = cam.CFrame
	end)
end

local function stopFly()
	if flyConnection then flyConnection:Disconnect() end
	if bv then bv:Destroy() end
	if bg then bg:Destroy() end
end

local function toggleFly()
	flying = not flying
	if flying then startFly() else stopFly() end
end

local function updateESP()
	espFolder:ClearAllChildren()
	if not espEnabled then return end
	for _, plr in pairs(Players:GetPlayers()) do
		if plr ~= player and plr.Character then
			local highlight = Instance.new("Highlight", espFolder)
			highlight.Adornee = plr.Character
			highlight.FillColor = Color3.fromRGB(255, 0, 0)
		end
	end
end

local function updateHealthESP()
	for _, plr in pairs(Players:GetPlayers()) do
		if plr ~= player and plr.Character and plr.Character:FindFirstChild("Head") then
			local head = plr.Character.Head
			local existing = head:FindFirstChild("HealthBarGui")
			if healthEspEnabled then
				if not existing then
					local bbg = Instance.new("BillboardGui", head)
					bbg.Name = "HealthBarGui"
					bbg.Size = UDim2.new(0, 100, 0, 20)
					bbg.StudsOffset = Vector3.new(0, 2, 0)
					bbg.AlwaysOnTop = true
					local label = Instance.new("TextLabel", bbg)
					label.BackgroundTransparency = 1
					label.Size = UDim2.new(1, 0, 1, 0)
					label.Font = Enum.Font.GothamBold
					label.TextSize = 12
				end
				local label = head.HealthBarGui.TextLabel
				local hum = plr.Character:FindFirstChildOfClass("Humanoid")
				if hum then
					label.Text = math.floor(hum.Health) .. " HP"
					label.TextColor3 = hum.Health > (hum.MaxHealth * 0.7) and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(255, 50, 50)
				end
			elseif existing then existing:Destroy() end
		end
	end
end

